# =============================================================================
# ARQUIVO DE EXEMPLO - VARIÁVEIS DE AMBIENTE
# =============================================================================
# 
# Este arquivo contém todas as variáveis de ambiente suportadas pela aplicação.
# Copie este arquivo e renomeie conforme o ambiente:
#
# Para desenvolvimento:  .env.development
# Para staging:          .env.staging  
# Para produção:         .env.production
#
# =============================================================================

# =============================================================================
# CONFIGURAÇÕES OBRIGATÓRIAS
# =============================================================================

# URL da API backend (obrigatório)
# Desenvolvimento: http://localhost:3000
# Staging:         https://api-staging.exemplo.com
# Produção:        https://c10rgiry67.execute-api.us-east-1.amazonaws.com/prod
VITE_API_URL=https://your-api-gateway-url.execute-api.region.amazonaws.com/stage

# Título da aplicação (use aspas para valores com espaços)
# Desenvolvimento: "Dashboard Admin (Dev)"
# Staging:         "Dashboard Admin (Staging)" 
# Produção:        "Dashboard Admin"
VITE_APP_TITLE="Your App Title"

# =============================================================================
# CONFIGURAÇÕES OPCIONAIS
# =============================================================================

# Versão da aplicação
VITE_APP_VERSION=1.0.0

# Ambiente de execução (development, staging, production)
VITE_ENVIRONMENT=production

# Modo debug (apenas desenvolvimento)
# VITE_DEBUG_MODE=true

# Nível de log (debug, info, warn, error)
# VITE_LOG_LEVEL=debug

# =============================================================================
# CONFIGURAÇÕES AVANÇADAS (OPCIONAL)
# =============================================================================

# Feature flags (descomente conforme necessário)
# VITE_FEATURE_CHARTS=enabled
# VITE_FEATURE_ADVANCED_AUTH=disabled

# API Gateway local para desenvolvimento com SAM
# VITE_API_URL=http://localhost:3001

# =============================================================================
# INSTRUÇÕES DE USO
# =============================================================================
#
# 1. COPIE este arquivo para o nome correto:
#    cp .env.example .env.development
#    cp .env.example .env.production
#
# 2. EDITE os valores conforme seu ambiente
#
# 3. IMPORTANTE: Use aspas para valores com espaços
#    ✅ Correto:   VITE_APP_TITLE="Dashboard Admin"
#    ❌ Incorreto: VITE_APP_TITLE=Dashboard Admin
#
# 4. SEGURANÇA: Nunca coloque dados sensíveis (senhas, tokens)
#    Todas as variáveis VITE_* ficam visíveis no bundle final
#
# 5. PREFIXO: Apenas variáveis com prefixo VITE_ são acessíveis no frontend
#
# =============================================================================