# Exemplo de configuração de variáveis de ambiente
# Copie este arquivo para .env.production ou .env.development e ajuste os valores

# URL da API backend (obrigatório)
VITE_API_URL=https://your-api-gateway-url.execute-api.region.amazonaws.com/stage

# Título da aplicação (use aspas para valores com espaços)
VITE_APP_TITLE="Your App Title"

# Versão da aplicação
VITE_APP_VERSION=1.0.0

# Ambiente de execução
VITE_ENVIRONMENT=production

# Instruções:
# 1. Remova este comentário
# 2. Substitua os valores pelos corretos
# 3. Salve como .env.production ou .env.development
# 4. IMPORTANTE: Use aspas para valores com espaços
#
# Exemplo correto:
# VITE_APP_TITLE="Dashboard Admin"
#
# Exemplo incorreto (causará erro):
# VITE_APP_TITLE=Dashboard Admin